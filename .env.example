# QuantBot 环境变量模板
# 复制为 .env 并填写真实值（.env 不提交到 git）

# --- 应用 ---
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# --- 数据库 ---
DB_USER=quantbot
DB_PASSWORD=CHANGE_ME
DB_NAME=quantbot
DATABASE_URL=postgresql+asyncpg://quantbot:CHANGE_ME@localhost:5432/quantbot

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
SECRET_KEY=GENERATE_WITH_openssl_rand_-hex_32

# --- 美股 Alpaca ---
# 申请: https://alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true    # true=沙盒 false=实盘

# --- 港股/美股 富途 ---
# 需安装 OpenD: https://openapi.futunn.com/futu-api-doc/
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
FUTU_TRADE_ENV=SIMULATE   # SIMULATE / REAL
FUTU_UNLOCK_PWD=           # 交易解锁密码

# --- 告警通知 (可选) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_WEBHOOK_URL=

# --- 期货 CTP (预留，暂不启用) ---
FUTURES_ENABLED=false
CTP_BROKER_ID=
CTP_INVESTOR_ID=
CTP_PASSWORD=
CTP_TD_ADDRESS=
CTP_MD_ADDRESS=

# --- 监控 ---
GRAFANA_PASSWORD=CHANGE_ME
