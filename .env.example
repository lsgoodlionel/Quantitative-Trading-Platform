# QuantBot 环境变量模板
# 用法: cp .env.example .env
#       然后填写所有 CHANGE_ME 字段
# 注意: .env 不提交到 git（已在 .gitignore 中忽略）

# ── 应用 ──────────────────────────────────────────────────────
ENVIRONMENT=development       # development | staging | production
LOG_LEVEL=INFO

# ── 数据库 (TimescaleDB/PostgreSQL) ──────────────────────────
DB_USER=quantbot
DB_PASSWORD=CHANGE_ME         # 生产环境使用强随机密码
DB_NAME=quantbot
# 注意: Docker Compose 中 DATABASE_URL 由 compose 文件自动组合，无需此处设置
# DATABASE_URL=postgresql+asyncpg://quantbot:CHANGE_ME@localhost:5432/quantbot

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=               # 生产环境建议设置密码
# REDIS_URL 由 compose 文件自动组合

# ── JWT 认证 ──────────────────────────────────────────────────
# 生成命令: openssl rand -hex 32
# 或运行:   make gen-secret
SECRET_KEY=CHANGE_ME_RUN_make_gen-secret

# ── CORS 允许来源 ─────────────────────────────────────────────
# 开发: http://localhost:3000,http://localhost:5173
# 生产: https://quantbot.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── 默认账号 ──────────────────────────────────────────────────
# 系统初始化后自动创建:  admin / admin123
# 生产环境务必通过 API 修改密码！
# POST /api/v1/auth/change-password

# ── 美股 Alpaca ───────────────────────────────────────────────
# 申请地址: https://alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true             # true=沙盒模式  false=实盘

# ── 港股/美股 富途 OpenD ──────────────────────────────────────
# 需本地运行 OpenD: https://openapi.futunn.com/futu-api-doc/
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
FUTU_TRADE_ENV=SIMULATE       # SIMULATE | REAL
FUTU_UNLOCK_PWD=              # 实盘解锁密码

# ── A 股沪深（akshare，免费，无需 Key）────────────────────────
# akshare 直接使用，无需 API Key

# ── 告警通知（可选）──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_WEBHOOK_URL=

# ── 期货 CTP（预留，Phase 8）─────────────────────────────────
FUTURES_ENABLED=false
CTP_BROKER_ID=
CTP_INVESTOR_ID=
CTP_PASSWORD=
CTP_TD_ADDRESS=
CTP_MD_ADDRESS=

# ── 监控 ──────────────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME    # Grafana 管理员密码
GRAFANA_PORT=3001             # Grafana 对外端口
# GRAFANA_DOMAIN=localhost    # 生产环境设置为实际域名

# ── 前端 ──────────────────────────────────────────────────────
FRONTEND_PORT=80              # 生产环境前端对外端口
